# ---------------------------------------------------------------------------
# WatchVerdict environment variables
# Copy to .env.local for local dev, and set these in Vercel for production.
# NEVER commit real values. Only NEXT_PUBLIC_* are exposed to the browser.
# ---------------------------------------------------------------------------

# --- Supabase (public, browser-safe) ---------------------------------------
# Project: WatchVerdict (ref vajgviraxigkwlvysxfz)
NEXT_PUBLIC_SUPABASE_URL=https://vajgviraxigkwlvysxfz.supabase.co
# Use the "publishable" (anon) key. Browser-safe by design.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# --- Supabase (server-only, SECRET) ----------------------------------------
# Service-role key. Server-only. NEVER prefix with NEXT_PUBLIC_.
# Only used by trusted server routes (e.g. account deletion). Optional for
# core usage; required for the account-deletion endpoint.
SUPABASE_SERVICE_ROLE_KEY=

# --- TMDB (server-only, SECRET) --------------------------------------------
# A TMDB API Read Access Token (v4 bearer) OR a v3 API key.
# Get one free at https://www.themoviedb.org/settings/api
TMDB_API_KEY=

# --- Site URL (public) ------------------------------------------------------
# The canonical public URL. Used for auth redirects, share links, OG tags.
# Local: http://localhost:3000 — Production: your Vercel/prod URL.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- OpenAI (server-only, OPTIONAL) ----------------------------------------
# Enhances report prose only. The app produces full deterministic verdicts
# without it. Leave blank to disable AI prose.
OPENAI_API_KEY=
