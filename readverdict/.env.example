# ReadVerdict environment
#
# ReadVerdict runs against the public Open Library API, which needs NO API key,
# so the app is fully runnable out of the box:
#
#   npm ci && npm run dev
#
# The only value worth setting is a descriptive contact for the outbound
# User-Agent (Open Library asks API clients to identify themselves). It is
# server-only and optional.

# Contact string sent in the Open Library User-Agent header (optional).
# Example: "ReadVerdict/0.1 (you@example.com)"
OPENLIBRARY_CONTACT=

# Public base URL of the deployment (used for absolute links / metadata).
# Optional in development.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
