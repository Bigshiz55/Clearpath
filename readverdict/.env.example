# ReadVerdict environment template
# Copy to .env.local and fill in. Never commit real secrets.
#
# The app boots and builds WITHOUT any of these set — Supabase and external
# data sources are wired to degrade gracefully until configured (Phase 3+).

# ---- Public site ----
# Absolute base URL of the deployment (used for metadata / absolute links).
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ---- Supabase (Phase 5+ auth & persistence) ----
# Safe to expose to the browser:
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only. MUST NOT be prefixed with NEXT_PUBLIC_ and never sent to the client:
SUPABASE_SERVICE_ROLE_KEY=

# ---- Recommendation / interpretation (Phase 4+) ----
# Server-only LLM key for the Search DNA parser. Optional; the parser has a
# deterministic fallback so the app runs without it.
OPENAI_API_KEY=

# ---- Book data providers (Phase 3+) ----
# Optional keys for metadata/availability providers. Absent = provider disabled.
GOOGLE_BOOKS_API_KEY=
OPENLIBRARY_CONTACT=

# ---- Analytics / consent (Phase 10) ----
# Left blank in development; analytics no-ops until configured & consented.
NEXT_PUBLIC_ANALYTICS_KEY=
