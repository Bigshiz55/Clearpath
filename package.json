{
  "name": "watchverdict",
  "version": "1.0.0",
  "private": true,
  "description": "WatchVerdict — a personalized movie & TV recommendation app with deterministic scoring, watchlists, and shareable verdicts.",
  "engines": {
    "node": ">=18.18.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "eval:selftest": "vitest run eval",
    "eval:watchverdict": "node eval/cli.mjs",
    "eval:watchverdict:smoke": "node eval/cli.mjs smoke",
    "eval:watchverdict:standard": "node eval/cli.mjs standard",
    "eval:watchverdict:full": "node eval/cli.mjs full",
    "eval:watchverdict:stress": "node eval/cli.mjs stress",
    "eval:watchverdict:regression": "node eval/cli.mjs regression",
    "eval:watchverdict:holdout": "node eval/cli.mjs holdout",
    "eval:watchverdict:live": "node eval/cli.mjs live",
    "eval:watchverdict:baseline": "node eval/cli.mjs baseline",
    "eval:watchverdict:compare": "node eval/cli.mjs compare",
    "eval:watchverdict:optimize": "node eval/cli.mjs optimize",
    "search-lab:baseline": "node eval/searchlab/cli.mjs baseline",
    "search-lab:gated": "node eval/searchlab/cli.mjs gated",
    "search-lab:regression": "node eval/searchlab/cli.mjs regression",
    "search-lab:holdout": "node eval/searchlab/cli.mjs holdout",
    "search-lab:compare": "node eval/searchlab/cli.mjs compare",
    "search-lab:calibrate": "vitest run --config eval/searchlab/calibration/vitest.calibration.config.ts",
    "search-lab:audit": "vitest run --config eval/searchlab/audit/vitest.audit.config.ts",
    "search-lab:benchmark": "vitest run --config eval/searchlab/benchmark/vitest.benchmark.config.ts"
  },
  "dependencies": {
    "@supabase/ssr": "^0.5.2",
    "@supabase/supabase-js": "^2.45.4",
    "html-to-image": "^1.11.13",
    "next": "^14.2.35",
    "pg": "^8.22.0",
    "qrcode": "^1.5.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "server-only": "^0.0.1",
    "tesseract.js": "^7.0.0",
    "web-push": "^3.6.7",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.14.10",
    "@types/pg": "^8.20.0",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/web-push": "^3.6.4",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.57.0",
    "eslint-config-next": "^14.2.35",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.13",
    "typescript": "^5.6.2",
    "vitest": "^3.2.7"
  }
}
