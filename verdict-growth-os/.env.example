# ─────────────────────────────────────────────────────────────────────────────
# Verdict Growth OS — environment template
#
# v1 runs entirely on labeled MOCK adapters, so NONE of these are required to
# run `npm run dev`, tests, or the build. They are the contract for when real
# integrations are enabled in later phases. Copy to `.env.local` and fill in.
#
# SECURITY: Nothing here may ever receive a NEXT_PUBLIC_ prefix except the two
# values explicitly marked "client-safe". Secrets are server-only.
# ─────────────────────────────────────────────────────────────────────────────

# --- Runtime -----------------------------------------------------------------
# Which adapter set to load. "mock" (default) uses seeded demo data only.
# "live" is rejected until the matching credentials below are present.
GROWTH_OS_MODE=mock

# --- Supabase (server-only) --------------------------------------------------
# Client-safe (these two MAY be exposed to the browser):
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only secret — NEVER expose to the client:
SUPABASE_SERVICE_ROLE_KEY=

# --- Analytics provider adapter (server-only) --------------------------------
# e.g. PostHog / Plausible / GA4. Left blank -> mock analytics adapter.
ANALYTICS_PROVIDER=mock
ANALYTICS_API_KEY=
ANALYTICS_PROJECT_ID=

# --- GitHub adapter (server-only) --------------------------------------------
# Fine-grained PAT, read-only scopes. Left blank -> mock github adapter.
GITHUB_PROVIDER=mock
GITHUB_TOKEN=
GITHUB_ORG=

# --- Revenue / billing adapter (server-only) ---------------------------------
# Stripe-style. Left blank -> mock revenue adapter. Never connect without
# explicit human approval (see docs/COST_CONTROL.md).
BILLING_PROVIDER=mock
STRIPE_SECRET_KEY=

# --- Social / outreach adapter (server-only) ---------------------------------
# v1 NEVER auto-posts. This is read/draft only until Approval Center is wired.
SOCIAL_PROVIDER=mock

# --- LLM (server-only) -------------------------------------------------------
# Used only for opportunity summarization/drafting in later phases.
OPENAI_API_KEY=

# --- Cost ceilings (safety) --------------------------------------------------
# Hard limits enforced by src/lib/domain/cost.ts. Jobs abort when exceeded.
GROWTH_OS_DAILY_LLM_USD_CEILING=5
GROWTH_OS_DAILY_JOB_RUN_CEILING=500
